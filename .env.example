# ── Database ──────────────────────────────────────────────────────────────────
# Neon: https://neon.tech → New Project → copy "pooled" connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-32-char-secret
# Must match your Vercel deployment URL (no trailing slash)
NEXTAUTH_URL=https://your-project.vercel.app

# ── Stripe ────────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Twilio (SMS for Venmo requests) ───────────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15735550100

# ── Resend (invoice emails) ───────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...

# ── Cloudinary (photo uploads) ────────────────────────────────────────────────
# cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
VENMO_BUSINESS_HANDLE=MidMoRollOffs
